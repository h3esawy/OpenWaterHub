			)
			(justify left top)
		)
		(uuid "a2cb9250-8dea-4b73-b9a5-6c8a4f5cc298")
	)
	(text_box "Role: Dedicated hardware and physical interface controller.\n\nTasks: Drives 4x PWM motor channels (J3, J7, J10, J11), reads local UI buttons (SW2-SW5), controls buzzer (LS1).\n\nComms: Receives commands wirelessly via LoRa (H4) or wired serial (H2). Physically isolated from the RS485 network."
		(exclude_from_sim no)
		(at 13.97 132.08 0)
		(size 55.88 22.86)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
