		(uuid "e0af411d-d3ae-4d84-934b-d9d28b2f0cc1")
	)
	(text_box "Role: Dedicated RS485 Node.\n\nTasks: Manages USB-to-PC bridge (M3) and drives the external RS485 network.\n\nComms: Broadcasts RS485 states wirelessly via LoRa (H3). Physically isolated from the motor drive circuits."
		(exclude_from_sim no)
